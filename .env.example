# Application
APP_SECRET_KEY=your-secret-key-here
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google OAuth2 (Gmail + Calendar)
GOOGLE_CLIENT_ID=your-google-client-id
